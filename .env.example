# Copy this file to .env and fill in your real values.
# NEVER commit .env to git.

# ── MetaTrader5 investor account ──────────────────────────────────────────────
MT5_LOGIN=921339
MT5_PASSWORD=your_investor_password_here
MT5_SERVER=MEXAtlantic-Real

# Path to the MetaTrader5 terminal executable (adjust to your installation)
# Example: C:\Program Files\MetaTrader 5\terminal64.exe
MT5_PATH=C:\Program Files\MetaTrader 5\terminal64.exe

# ── Project settings ──────────────────────────────────────────────────────────
# Timezone for MT5 server (usually UTC for ECN brokers)
MT5_TIMEZONE=UTC

# Symbol to trade
SYMBOL=XAUUSD

# Primary timeframe
TIMEFRAME=M15
